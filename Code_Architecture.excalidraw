      "id": "SmxCedDD19iO6TPeiP0BQ",
      "type": "text",
      "x": 853.2700047103681,
      "y": 338.4966574340342,
      "width": 680.2708129882812,
      "height": 765,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff5f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
